# ============================================================================
# Terraform Variables - Security Auditing Lab
# ============================================================================
# Copy this file to terraform.tfvars and adjust values as needed.
# ============================================================================

aws_region = "ap-southeast-1"

environment = "lab"

project_name = "security-audit"

vpc_a_cidr = "10.0.0.0/16"

vpc_a_public_subnet_cidr = "10.0.1.0/24"

vpc_b_cidr = "10.1.0.0/16"

vpc_b_private_subnet_cidr = "10.1.1.0/24"

instance_type = "t2.micro"

enable_dns_support = true

enable_dns_hostnames = true

assign_public_ip_public_subnet = true

tags = {
  CostCenter = "Security"
  Automation = "Terraform"
}
